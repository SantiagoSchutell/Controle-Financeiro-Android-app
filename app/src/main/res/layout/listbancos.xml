<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/textNomebanco"
        android:layout_width="241dp"
        android:layout_height="22dp"
        android:layout_marginStart="8dp"
        android:text="@string/app_textNomebanco"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/bancoLogo"
        app:layout_constraintTop_toTopOf="@+id/bancoLogo" />

    <TextView
        android:id="@+id/textTipoConta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/radioContaCorrente"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="@+id/textNomebanco"
        app:layout_constraintTop_toBottomOf="@+id/textNomebanco" />

    <ImageView
        android:id="@+id/bancoLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars" />

</androidx.constraintlayout.widget.ConstraintLayout>